@article{b053c0e7-e2d5-3dd5-93ba-a1adab8d3d90,
 ISSN = {00031305, 15372731},
 URL = {http://www.jstor.org/stable/2683142},
 abstract = {Letters from W.S. Gosset to R.A. Fisher are used to describe Gosset's first contacts and growing friendship with Fisher, their collaboration over the tabulation of Student's t, and the wider applications of Gosset's work that were made possible by Fisher's extension and generalization of the distribution theory in the early 1920's. These letters reveal Gosset's practical approach to the statistical problems of his brewery work that "naturally required" the solutions for which the name of Student is famous; and they exhibit his appealing character, modest yet self-reliant, in relationship not only to Karl Pearson and R.A. Fisher but to statistical assistants still in training.},
 author = {Joan Fisher Box},
 journal = {The American Statistician},
 number = {2},
 pages = {61--66},
 publisher = {[American Statistical Association, Taylor & Francis, Ltd.]},
 title = {Gosset, Fisher, and the t Distribution},
 urldate = {2026-06-15},
 volume = {35},
 year = {1981}
}


